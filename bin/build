#!/bin/bash
# R-ShareMouse Universal Build Script
# Detects the platform and calls the appropriate build script

set -e

# Detect OS
if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS
    "$(dirname "$0")/macos/build.sh" "$@"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    # Linux
    "$(dirname "$0")/linux/build.sh" "$@"
else
    echo "Unsupported OS: $OSTYPE"
    echo "Please use the appropriate script in bin/windows/ on Windows."
    exit 1
fi
