{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "R-ShareMouse",
  "version": "0.1.0",
  "identifier": "com.rsharemouse.desktop",
  "build": {
    "beforeBuildCommand": "npm --prefix ../../../other/figma-ui run build",
    "frontendDist": "../../../other/figma-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "R-ShareMouse",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
